# fumii environment variables
# Copy this to .env and fill in your values
# API keys are stored in OS keychain at runtime — these are only for dev overrides

# LLM Provider (mistral | openai | anthropic | ollama)
LLM_PROVIDER=mistral

# Only needed for development — production uses OS keychain via keytar
# MISTRAL_API_KEY=your_key_here
# OPENAI_API_KEY=your_key_here
# ANTHROPIC_API_KEY=your_key_here

# Ollama base URL (only if using local models)
OLLAMA_BASE_URL=http://localhost:11434

# Dev mode logging
LOG_LEVEL=info
