{
  "appId": "com.fumii.app",
  "productName": "fumii",
  "copyright": "fumii contributors",
  "icon": "build/icon.png",
  "directories": {
    "output": "release",
    "buildResources": "build"
  },
  "files": [
    "dist/**/*",
    "package.json",
    "!dist/**/*.map"
  ],
  "extraResources": [
    {
      "from": "src/assets",
      "to":   "assets"
    }
  ],
  "win": {
    "target":          [{ "target": "nsis", "arch": ["x64"] }],
    "icon":            "build/icon.ico",
    "artifactName":   "${productName}-setup-${version}.${ext}"
  },
  "nsis": {
    "oneClick":                false,
    "perMachine":              true,
    "allowToChangeInstallationDirectory": true,
    "deleteAppDataOnUninstall": false,
    "createDesktopShortcut":   true,
    "createStartMenuShortcut": true
  },
  "asar":       true,
  "asarUnpack": [
    "**/node_modules/better-sqlite3/**",
    "**/node_modules/keytar/**"
  ]
}
